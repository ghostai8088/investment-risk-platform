# Frontend build-time configuration (Vite). `VITE_`-prefixed vars are INLINED at `npm run build`,
# not read at runtime. Copy to `.env` for local overrides. The default is the dev_header demo path,
# so `npm run dev` works with no OIDC setup. See `10_delivery_backlog/fe_3b_decision_record.md`.

# Auth mode — mirrors the backend AUTH_MODE.
#   dev_header : the local demo; identity is unverified (the DevBanner shows); NOT a security boundary.
#   oidc       : the real browser auth-code + PKCE login against Keycloak (a verified Bearer session).
VITE_AUTH_MODE=dev_header

# OIDC settings (only used when VITE_AUTH_MODE=oidc) — must match the Keycloak `irp-frontend`
# public client (infra/keycloak/irp-local-realm.json). NO client secret (public client + PKCE).
# VITE_OIDC_ISSUER=http://localhost:8080/realms/irp-local
# VITE_OIDC_CLIENT_ID=irp-frontend
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
