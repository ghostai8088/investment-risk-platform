{
  "realm": "irp-local",
  "enabled": true,
  "sslRequired": "none",
  "loginTheme": "keycloak",
  "accessTokenLifespan": 300,
  "clients": [
    {
      "clientId": "irp-frontend",
      "name": "IRP frontend (SPA, auth-code + PKCE)",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": ["http://localhost:5173/*"],
      "webOrigins": ["http://localhost:5173"],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*"
      },
      "protocolMappers": [
        {
          "name": "tenant_id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "tenant_id",
            "claim.name": "tenant_id",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "sub-from-username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "sub",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "audience-irp-backend",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-mapper",
          "config": {
            "included.custom.audience": "irp-backend",
            "id.token.claim": "false",
            "access.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "demo-validator",
      "enabled": true,
      "emailVerified": true,
      "firstName": "Andrew",
      "lastName": "Cox",
      "attributes": {
        "tenant_id": ["8c3193a6-1c9c-5353-bbe1-ab8716e986a9"]
      },
      "credentials": [{ "type": "password", "value": "demo", "temporary": false }]
    },
    {
      "username": "demo-registrar",
      "enabled": true,
      "attributes": {
        "tenant_id": ["8c3193a6-1c9c-5353-bbe1-ab8716e986a9"]
      },
      "credentials": [{ "type": "password", "value": "demo", "temporary": false }]
    },
    {
      "username": "demo-auditor",
      "enabled": true,
      "firstName": "Demo",
      "lastName": "Auditor",
      "attributes": {
        "tenant_id": ["8c3193a6-1c9c-5353-bbe1-ab8716e986a9"]
      },
      "credentials": [{ "type": "password", "value": "demo", "temporary": false }]
    }
  ]
}
