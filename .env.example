# Copy to .env for local development. DO NOT commit .env. No production secrets here (BR-10).
APP_ENV=local
APP_VERSION=0.1.0
BACKEND_PORT=8000

# Local-only Postgres placeholders. Set your own local values; never use in production.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=irp
POSTGRES_USER=irp
POSTGRES_PASSWORD=change-me-locally

# Used by Alembic migrations and the backend session factory (psycopg driver).
# Points at the local docker-compose Postgres service. Local-only placeholder password.
DATABASE_URL=postgresql+psycopg://irp:change-me-locally@localhost:5432/irp
