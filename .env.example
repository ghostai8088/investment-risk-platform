# Copy to .env for local development. DO NOT commit .env. No production secrets here (BR-10).
APP_ENV=local
APP_VERSION=0.1.0
BACKEND_PORT=8000

# Local-only Postgres placeholders. Set your own local values; never use in production.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=irp
POSTGRES_USER=irp
POSTGRES_PASSWORD=change-me-locally

# Used by Alembic migrations and the backend session factory (psycopg driver).
# Points at the local docker-compose Postgres service. Local-only placeholder password.
DATABASE_URL=postgresql+psycopg://irp:change-me-locally@localhost:5432/irp

# --- Identity / authentication (SSO-1, AD-007) ---
# auth_mode: "oidc" (default, verify a real Bearer JWT) or "dev_header" (the unverified
# X-User-Id/X-Tenant-Id shim — permitted ONLY when APP_ENV=local; DR-P1A0-3).
# Local dev without an IdP running uses the shim:
AUTH_MODE=dev_header
# For OIDC (e.g. against the local Keycloak realm) set AUTH_MODE=oidc; OIDC_ISSUER and
# OIDC_AUDIENCE are then BOTH required (the app refuses to start otherwise — audience restriction
# blocks tokens minted for another client of the same realm). NO client secret here (BR-10).
# OIDC_ISSUER=http://localhost:8080/realms/irp-local
# OIDC_AUDIENCE=irp-backend
# OIDC_JWKS_URI=            # optional; discovered from {issuer}/.well-known/openid-configuration
# OIDC_TENANT_CLAIM=tenant_id
# OIDC_REQUIRE_MFA=false
#
# FE-3b — the FULL `docker compose --profile oidc up` login demo. The browser reaches Keycloak at
# localhost:8080 (so the token iss is localhost), but the backend runs IN the compose network, where
# `localhost:8080` is the backend container, NOT Keycloak. So JWKS auto-discovery to the issuer host
# FAILS and every login 503s. Fix: keep OIDC_ISSUER=localhost (to match the token) but point
# OIDC_JWKS_URI at the keycloak SERVICE name (the certs endpoint embeds no issuer, so cross-host is
# fine). Uncomment ALL of the following to run the demo (see infra/keycloak/README.md):
# AUTH_MODE=oidc
# OIDC_ISSUER=http://localhost:8080/realms/irp-local
# OIDC_AUDIENCE=irp-backend
# OIDC_JWKS_URI=http://keycloak:8080/realms/irp-local/protocol/openid-connect/certs
# VITE_AUTH_MODE=oidc
# VITE_OIDC_ISSUER=http://localhost:8080/realms/irp-local
# VITE_OIDC_CLIENT_ID=irp-frontend
# VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
#
# Local Keycloak dev IdP (docker compose --profile oidc up keycloak) — local-only admin creds:
# KEYCLOAK_ADMIN_USER=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
